// ============================================================
// MIXED MEGA GAME
// ============================================================
function MixedGame({ onBack, onXP }) {
  const ROUNDS = 15;
  const words = useMemo(() => [...HSK1_WORDS].sort(()=>Math.random()-0.5).slice(0, ROUNDS), []);
  const [idx, setIdx] = useState(0);
  const [score, setScore] = useState(0);
  const [answered, setAnswered] = useState(null);
  const [flipped, setFlipped] = useState(false);
  const [flashDone, setFlashDone] = useState(false);
  const [finished, setFinished] = useState(false);
  const [phase, setPhase] = useState("flash"); // flash → match → done

  const w = words[idx % words.length];

  // Phase 1: Flashcard (birinchi 5 ta)
  const flashWords = words.slice(0,5);
  const matchWords = words.slice(5, ROUNDS);

  const matchOptions = useMemo(() => {
    if (!w || phase!=="match") return [];
    const wrong = HSK1_WORDS.filter(x=>x.id!==w.id).sort(()=>Math.random()-0.5).slice(0,3).map(x=>x.uzbek);
    return [...wrong, w.uzbek].sort(()=>Math.random()-0.5);
  }, [idx, phase]);

  const handleMatch = (opt) => {
    if (answered!==null) return;
    setAnswered(opt);
    if (opt===w.uzbek) setScore(s=>s+1);
    setTimeout(()=>{
      const nextIdx = idx+1;
      if (nextIdx >= matchWords.length + flashWords.length) { setFinished(true); onXP && onXP(50); }
      else { setIdx(nextIdx); setAnswered(null); setFlipped(false); }
    }, 700);
  };

  if (finished) return (
    <div style={{ height:"100vh", display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", padding:24, textAlign:"center", background:T.bg }}>
      <div style={{ fontSize:64, marginBottom:16 }}>{score>=ROUNDS*0.7?"🏆":score>=ROUNDS*0.5?"⭐":"📚"}</div>
      <div style={{ fontSize:36, fontWeight:900, color:T.gold }}>{score}/{ROUNDS}</div>
      <div style={{ fontSize:16, color:T.textMuted, marginTop:8 }}>+50 XP qo’shildi!</div>
      <div style={{ marginTop:32, display:"flex", gap:12 }}>
        <button onClick={onBack} style={{ background:T.gradient, border:"none", borderRadius:14, padding:"14px 28px", color:"#fff", fontWeight:700, cursor:"pointer" }}>Chiqish</button>
      </div>
    </div>
  );

  // Flash phase
  if (!flashDone && idx < flashWords.length) {
    const fw = flashWords[idx];
    return (
      <div style={{ height:"100vh", display:"flex", flexDirection:"column", background:T.bg }}>
        <div style={{ background:T.gradient, padding:"52px 16px 16px", display:"flex", alignItems:"center", gap:12 }}>
          <button onClick={onBack} style={{ background:"rgba(0,0,0,0.2)", border:"none", borderRadius:10, width:36, height:36, color:"#fff", fontSize:20, cursor:"pointer" }}>‹</button>
          <div style={{ flex:1, fontSize:14, color:"rgba(255,255,255,0.8)" }}>🌟 Mega O'yin — Yodlash ({idx+1}/5)</div>
        </div>
        <div style={{ flex:1, display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", padding:24 }}>
          <div onClick={()=>setFlipped(f=>!f)}
            style={{ width:"100%", background:flipped?"linear-gradient(135deg,rgba(244,196,48,0.15),rgba(230,57,70,0.1))":T.card, border:`1px solid ${flipped?T.gold:T.border}`, borderRadius:24, padding:40, textAlign:"center", cursor:"pointer", minHeight:220, display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", transition:"all 0.3s" }}>
            {!flipped ? (
              <>
                <div style={{ fontSize:72, fontWeight:900, color:T.text }}>{fw.hanzi}</div>
                <div style={{ fontSize:20, color:T.textMuted, marginTop:8 }}>{fw.pinyin}</div>
                <div style={{ fontSize:12, color:T.textMuted, marginTop:20 }}>👆 Tap — tarjimani ko’r</div>
              </>
            ) : (
              <>
                <div style={{ fontSize:28, fontWeight:900, color:T.gold, marginBottom:8 }}>{fw.uzbek}</div>
                <div style={{ fontSize:15, color:T.text }}>{fw.s1zh}</div>
                <div style={{ fontSize:13, color:T.textMuted, marginTop:4 }}>{fw.s1uz}</div>
              </>
            )}
          </div>
          <div style={{ display:"flex", gap:12, marginTop:28 }}>
            <button onClick={()=>{setIdx(i=>Math.max(0,i-1));setFlipped(false);}}
              style={{ background:T.card, border:`1px solid ${T.border}`, borderRadius:14, padding:"14px 28px", color:T.text, fontSize:20, cursor:"pointer" }}>‹</button>
            <button onClick={()=>{
              const next=idx+1;
              if(next>=flashWords.length){setFlashDone(true);setIdx(0);}
              else{setIdx(next);setFlipped(false);}
            }}
              style={{ background:T.gradient, border:"none", borderRadius:14, padding:"14px 28px", color:"#fff", fontSize:15, fontWeight:700, cursor:"pointer" }}>
              {idx+1>=flashWords.length?"Test boshlash ›":"Keyingi ›"}
            </button>
          </div>
        </div>
      </div>
    );
  }

  // Match phase
  const matchIdx = flashDone ? idx : idx - flashWords.length;
  const mw = matchWords[matchIdx % matchWords.length];

  return (
    <div style={{ height:"100vh", display:"flex", flexDirection:"column", background:T.bg }}>
      <div style={{ background:T.gradient, padding:"52px 16px 16px", display:"flex", alignItems:"center", gap:12 }}>
        <button onClick={onBack} style={{ background:"rgba(0,0,0,0.2)", border:"none", borderRadius:10, width:36, height:36, color:"#fff", fontSize:20, cursor:"pointer" }}>‹</button>
        <div style={{ flex:1 }}>
          <div style={{ fontSize:13, color:"rgba(255,255,255,0.8)", marginBottom:4 }}>🌟 Mega O'yin — Test ({matchIdx+1}/{matchWords.length}) · ✓{score}</div>
          <div style={{ height:4, background:"rgba(0,0,0,0.2)", borderRadius:2 }}>
            <div style={{ height:"100%", width:`${((matchIdx+1)/matchWords.length)*100}%`, background:T.gold, borderRadius:2, transition:"width 0.3s" }} />
          </div>
        </div>
      </div>
      <div style={{ flex:1, display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", padding:24 }}>
        <div style={{ fontSize:76, fontWeight:900, color:T.text, marginBottom:6 }}>{mw?.hanzi}</div>
        <div style={{ fontSize:18, color:T.textMuted, marginBottom:36 }}>{mw?.pinyin}</div>
        <div style={{ width:"100%", display:"grid", gridTemplateColumns:"1fr 1fr", gap:12 }}>
          {matchOptions.map((opt,i)=>{
            let bg=T.card, border=T.border, color=T.text;
            if(answered!==null){
              if(opt===mw?.uzbek){bg="rgba(86,207,114,0.2)";border=T.green;color=T.green;}
              else if(opt===answered){bg="rgba(230,57,70,0.2)";border=T.red;color=T.red;}
            }
            return (
              <button key={i} onClick={()=>handleMatch(opt)}
                style={{ background:bg, border:`2px solid ${border}`, borderRadius:14, padding:"18px 10px", color, fontSize:14, fontWeight:700, cursor:"pointer", transition:"all 0.2s" }}>
                {opt}
              </button>
            );
          })}
        </div>
      </div>
    </div>
  );
}

// ============================================================
// MATCH4 GAME
// ============================================================
function Match4Game({ words: W = HSK1_WORDS, onBack, onXP }) {
  const TOTAL = Math.min(10, W.length);
  const shuffled = useMemo(() => [...W].sort(() => Math.random() - 0.5).slice(0, TOTAL), []);
  const [idx, setIdx] = useState(0);
  const [score, setScore] = useState(0);
  const [answered, setAnswered] = useState(null);
  const [finished, setFinished] = useState(false);

  const current = shuffled[idx];
  const options = useMemo(() => {
    if (!current) return [];
    const wrong = HSK1_WORDS.filter(w => w.id !== current.id).sort(() => Math.random() - 0.5).slice(0, 3).map(w => w.uzbek);
    return [...wrong, current.uzbek].sort(() => Math.random() - 0.5);
  }, [idx, shuffled]);

  const handleAnswer = (opt) => {
    if (answered !== null) return;
    setAnswered(opt);
    if (opt === current.uzbek) setScore(s => s + 1);
    setTimeout(() => {
      if (idx + 1 >= TOTAL) { setFinished(true); onXP && onXP(10); }
      else { setIdx(i => i + 1); setAnswered(null); }
    }, 800);
  };

  if (finished) return <ResultScreen score={score} total={TOTAL} onBack={onBack} />;

  return (
    <div style={{ height: "100vh", display: "flex", flexDirection: "column" }}>
      <GameHeader title="4 Variant" score={score} idx={idx} total={TOTAL} onBack={onBack} />
      <div style={{ flex: 1, display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", padding: 24 }}>
        <div style={{ fontSize: 80, fontWeight: 900, color: T.text, marginBottom: 8 }}>{current.hanzi}</div>
        <div style={{ fontSize: 18, color: T.textMuted, marginBottom: 40 }}>{current.pinyin}</div>
        <div style={{ width: "100%", display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
          {options.map((opt, i) => {
            let bg = T.card, border = T.border, color = T.text;
            if (answered !== null) {
              if (opt === current.uzbek) { bg = "rgba(86,207,114,0.2)"; border = T.green; color = T.green; }
              else if (opt === answered && opt !== current.uzbek) { bg = "rgba(230,57,70,0.2)"; border = T.red; color = T.red; }
            }
            return (
              <button key={i} onClick={() => handleAnswer(opt)}
                style={{ background: bg, border: `2px solid ${border}`, borderRadius: 14, padding: "18px 12px", color, fontSize: 14, fontWeight: 700, cursor: "pointer", transition: "all 0.2s" }}>
                {opt}
              </button>
            );
          })}
        </div>
      </div>
    </div>
  );
}

