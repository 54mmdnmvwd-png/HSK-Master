// READING SECTION
// ============================================================
function ReadingSection({ data }) {
  const [mode, setMode] = useState("text"); // text | quiz | fill
  const [qIdx, setQIdx] = useState(0);
  const [selected, setSelected] = useState(null);
  const [score, setScore] = useState(0);
  const [done, setDone] = useState(false);
  const [fillAnswers, setFillAnswers] = useState({});
  const [fillChecked, setFillChecked] = useState(false);
  const [showPy, setShowPy] = useState(false);
  const [showUz, setShowUz] = useState(false);

  const speak = (text) => { if ("speechSynthesis" in window) { const u = new SpeechSynthesisUtterance(text); u.lang = "zh-CN"; u.rate = 0.75; speechSynthesis.speak(u); } };

  const resetQuiz = () => { setQIdx(0); setSelected(null); setScore(0); setDone(false); };

  return (
    <div>
      {/* Mode buttons */}
      <div style={{ display: "flex", gap: 8, marginBottom: 16 }}>
        {[["text","📄 Matn"],["quiz","❓ Savol"],["fill","✏️ To'ldirish"]].map(([id,label]) => (
          <button key={id} onClick={() => { setMode(id); resetQuiz(); setFillAnswers({}); setFillChecked(false); }}
            style={{ flex: 1, padding: "10px 6px", borderRadius: 10, border: `1px solid ${mode===id?T.red:T.border}`, background: mode===id?"rgba(230,57,70,0.15)":T.card, color: mode===id?T.red:T.textMuted, fontSize: 12, fontWeight: mode===id?700:400, cursor: "pointer" }}>
            {label}
          </button>
        ))}
      </div>

      {/* TEXT MODE */}
      {mode === "text" && (
        <div>
          <div style={{ background: T.card, borderRadius: 14, padding: 16, marginBottom: 12, border: `1px solid ${T.border}` }}>
            <div style={{ fontSize: 16, fontWeight: 800, color: T.gold, marginBottom: 12 }}>{data.text.title}</div>
            <div style={{ display: "flex", gap: 8, marginBottom: 12 }}>
              {[["showPy","拼音",showPy,()=>setShowPy(p=>!p)],["showUz","O'zbek",showUz,()=>setShowUz(p=>!p)]].map(([k,label,on,toggle]) => (
                <button key={k} onClick={toggle}
                  style={{ padding: "6px 12px", borderRadius: 8, border: `1px solid ${on?T.gold:T.border}`, background: on?"rgba(244,196,48,0.15)":T.bg, color: on?T.gold:T.textMuted, fontSize: 12, cursor: "pointer" }}>
                  {label}
                </button>
              ))}
            </div>
            {data.text.lines.map((line, i) => (
              <div key={i} style={{ marginBottom: 12, padding: "10px 12px", background: T.bg, borderRadius: 10, borderLeft: `3px solid ${i%2===0?T.red:T.gold}` }}>
                <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start" }}>
                  <div style={{ flex: 1 }}>
                    <div style={{ fontSize: 15, color: T.text, fontWeight: 600 }}>{line.zh}</div>
                    {showPy && <div style={{ fontSize: 12, color: T.blue, marginTop: 3 }}>{line.py}</div>}
                    {showUz && <div style={{ fontSize: 13, color: T.textMuted, marginTop: 3, fontStyle: "italic" }}>{line.uz}</div>}
                  </div>
                  <button onClick={() => speak(line.zh)} style={{ background: "none", border: "none", fontSize: 18, cursor: "pointer", marginLeft: 8 }}>🔊</button>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* QUIZ MODE */}
      {mode === "quiz" && (
        <div>
          {!done ? (
            <div style={{ background: T.card, borderRadius: 14, padding: 16, border: `1px solid ${T.border}` }}>
              <div style={{ fontSize: 12, color: T.textMuted, marginBottom: 12 }}>{qIdx+1}/{data.questions.length} · ✓ {score}</div>
              <div style={{ fontSize: 16, fontWeight: 700, color: T.text, marginBottom: 16 }}>{data.questions[qIdx].q}</div>
              {data.questions[qIdx].opts.map((opt, i) => {
                let bg = T.bg, border = T.border, color = T.text;
                if (selected !== null) {
                  if (i === data.questions[qIdx].ans) { bg = "rgba(86,207,114,0.2)"; border = T.green; color = T.green; }
                  else if (i === selected) { bg = "rgba(230,57,70,0.2)"; border = T.red; color = T.red; }
                }
                return (
                  <button key={i} onClick={() => {
                    if (selected !== null) return;
                    setSelected(i);
                    if (i === data.questions[qIdx].ans) setScore(s=>s+1);
                    setTimeout(() => {
                      if (qIdx+1 >= data.questions.length) setDone(true);
                      else { setQIdx(q=>q+1); setSelected(null); }
                    }, 700);
                  }}
                    style={{ width: "100%", background: bg, border: `2px solid ${border}`, borderRadius: 12, padding: "13px 16px", color, fontSize: 15, fontWeight: 600, cursor: "pointer", marginBottom: 10, textAlign: "left", transition: "all 0.2s" }}>
                    {opt}
                  </button>
                );
              })}
            </div>
          ) : (
            <div style={{ textAlign: "center", padding: 32 }}>
              <div style={{ fontSize: 48, marginBottom: 12 }}>{score === data.questions.length ? "🏆" : "⭐"}</div>
              <div style={{ fontSize: 28, fontWeight: 900, color: T.gold }}>{score}/{data.questions.length}</div>
              <div style={{ fontSize: 14, color: T.textMuted, marginTop: 8, marginBottom: 24 }}>{score === data.questions.length ? "Mukammal!" : "Yana bir marta!"}</div>
              <button onClick={resetQuiz} style={{ background: T.gradient, border: "none", borderRadius: 12, padding: "12px 28px", color: "#fff", fontWeight: 700, cursor: "pointer" }}>🔄 Qayta</button>
            </div>
          )}
        </div>
      )}

      {/* FILL BLANKS */}
      {mode === "fill" && (
        <div>
          <div style={{ background: T.card, borderRadius: 14, padding: 16, border: `1px solid ${T.border}`, marginBottom: 12 }}>
            <div style={{ fontSize: 14, fontWeight: 700, color: T.gold, marginBottom: 14 }}>Bo’sh joyni to’ldiring:</div>
            {data.fillBlanks.map((item, i) => {
              const userAns = fillAnswers[i] || "";
              const isCorrect = fillChecked && userAns.trim() === item.answer;
              const isWrong = fillChecked && userAns.trim() !== item.answer;
              return (
                <div key={i} style={{ marginBottom: 16 }}>
                  <div style={{ fontSize: 14, color: T.textMuted, marginBottom: 6 }}>💡 {item.hint}</div>
                  <div style={{ display: "flex", alignItems: "center", gap: 8, fontSize: 18, color: T.text, fontWeight: 600, flexWrap: "wrap" }}>
                    {item.sentence.split("___").map((part, j, arr) => (
                      <span key={j} style={{ display: "flex", alignItems: "center", gap: 6 }}>
                        {part}
                        {j < arr.length - 1 && (
                          <input value={userAns} onChange={e => setFillAnswers(f=>({...f,[i]:e.target.value}))}
                            disabled={fillChecked}
                            style={{ width: 70, background: isCorrect?"rgba(86,207,114,0.15)":isWrong?"rgba(230,57,70,0.15)":T.bg, border: `2px solid ${isCorrect?T.green:isWrong?T.red:T.border}`, borderRadius: 8, padding: "4px 8px", color: isCorrect?T.green:isWrong?T.red:T.text, fontSize: 18, textAlign: "center", outline: "none" }} />
                        )}
                      </span>
                    ))}
                    {fillChecked && <span style={{ fontSize: 18 }}>{isCorrect?"✅":"❌"}</span>}
                  </div>
                  {fillChecked && isWrong && <div style={{ fontSize: 13, color: T.green, marginTop: 4 }}>✓ To'g'ri: {item.answer}</div>}
                </div>
              );
            })}
          </div>
          {!fillChecked ? (
            <button onClick={() => setFillChecked(true)}
              style={{ width: "100%", background: T.gradient, border: "none", borderRadius: 12, padding: "13px", color: "#fff", fontWeight: 700, fontSize: 15, cursor: "pointer" }}>
              ✓ Tekshirish
            </button>
          ) : (
            <button onClick={() => { setFillAnswers({}); setFillChecked(false); }}
              style={{ width: "100%", background: T.card, border: `1px solid ${T.border}`, borderRadius: 12, padding: "13px", color: T.text, fontWeight: 700, fontSize: 15, cursor: "pointer" }}>
              🔄 Qayta urinish
            </button>
          )}
        </div>
      )}
    </div>
  );
}

