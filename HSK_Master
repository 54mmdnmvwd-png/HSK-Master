}

function WritingSection({ lessonId }) {
  const data = LESSONS_WRITING[lessonId];
  const [mode, setMode] = useState("zh2uz"); // zh2uz | uz2zh | order
  const [idx, setIdx] = useState(0);
  const [answer, setAnswer] = useState("");
  const [checked, setChecked] = useState(false);
  const [score, setScore] = useState(0);
  const [total, setTotal] = useState(0);
  const [orderSel, setOrderSel] = useState([]);

  if (!data) return <ComingSoon label="Writing" />;

  const items = mode==="zh2uz" ? data.zh2uz : mode==="uz2zh" ? data.uz2zh : data.wordOrder;
  const item = items[idx % items.length];

  const checkAnswer = () => {
    if (mode==="order") return;
    setChecked(true);
    setTotal(t=>t+1);
    const correct = mode==="zh2uz" ? item.uz : item.zh;
    const norm = s => s.trim().replace(/[。！？，,!?.]/g,"").toLowerCase();
    if (norm(answer) === norm(correct)) setScore(s=>s+1);
  };

  const next = () => { setIdx(i=>(i+1)%items.length); setAnswer(""); setChecked(false); setOrderSel([]); };

  const correct = mode==="zh2uz" ? item.uz : item.zh;
  const norm = s => s.trim().replace(/[。！？，,!?.]/g,"").toLowerCase();
  const isCorrect = checked && norm(answer) === norm(correct);

  // Word order game
  const shuffledWords = useMemo(() => {
    if (mode!=="order") return [];
    return [...(item.words||[])].sort(()=>Math.random()-0.5);
  }, [idx, mode]);

  const handleOrderTap = (w) => {
    if (orderSel.includes(w)) setOrderSel(s=>s.filter(x=>x!==w));
    else setOrderSel(s=>[...s,w]);
  };
  const orderCorrect = orderSel.join("")===item?.correct?.replace(/[。！？，]/g,"");

  return (
    <div>
      {/* Mode tabs */}
      <div style={{ display:"flex", gap:8, marginBottom:14 }}>
        {[["zh2uz","中→O'zbek"],["uz2zh","O'zbek→中"],["order","Tartiblash"]].map(([id,label])=>(
          <button key={id} onClick={()=>{setMode(id);setIdx(0);setAnswer("");setChecked(false);setOrderSel([]);}}
            style={{ flex:1, padding:"9px 4px", borderRadius:10, border:`1px solid ${mode===id?T.red:T.border}`, background:mode===id?"rgba(230,57,70,0.15)":T.card, color:mode===id?T.red:T.textMuted, fontSize:11, fontWeight:mode===id?700:400, cursor:"pointer" }}>
            {label}
          </button>
        ))}
      </div>

      {/* Score */}
      {total>0 && mode!=="order" && (
        <div style={{ display:"flex", justifyContent:"space-between", fontSize:12, color:T.textMuted, marginBottom:10 }}>
          <span>Savol {idx+1}/{items.length}</span>
          <span>✓ {score}/{total}</span>
        </div>
      )}

      {/* ZH→UZ / UZ→ZH */}
      {mode !== "order" && (
        <div>
          <div style={{ background:T.card, borderRadius:14, padding:16, border:`1px solid ${T.border}`, marginBottom:12 }}>
            <div style={{ fontSize:12, color:T.gold, fontWeight:700, marginBottom:8 }}>{mode==="zh2uz"?"Xitoycha:":"O'zbekcha:"}</div>
            <div style={{ fontSize:mode==="zh2uz"?20:16, fontWeight:700, color:T.text, lineHeight:1.5 }}>
              {mode==="zh2uz" ? item.zh : item.uz}
            </div>
          </div>
          <div style={{ fontSize:12, color:T.textMuted, marginBottom:6 }}>{mode==="zh2uz"?"O'zbekchaga tarjima qiling:":"Xitoychaga tarjima qiling:"}</div>
          <textarea value={answer} onChange={e=>setAnswer(e.target.value)} disabled={checked}
            placeholder={mode==="zh2uz"?"O'zbekcha tarjimangizni yozing...":"Xitoycha tarjimangizni yozing..."}
            rows={3}
            style={{ width:"100%", background:checked?(isCorrect?"rgba(86,207,114,0.1)":"rgba(230,57,70,0.1)"):T.card, border:`1px solid ${checked?(isCorrect?T.green:T.red):T.border}`, borderRadius:12, padding:"12px 14px", color:T.text, fontSize:15, boxSizing:"border-box", outline:"none", resize:"none", fontFamily:"inherit" }} />

          {checked && (
            <div style={{ background:isCorrect?"rgba(86,207,114,0.1)":"rgba(230,57,70,0.08)", border:`1px solid ${isCorrect?T.green:T.red}`, borderRadius:10, padding:12, marginTop:8 }}>
              <div style={{ fontSize:14, fontWeight:700, color:isCorrect?T.green:T.red, marginBottom:4 }}>
                {isCorrect ? "✅ To'g'ri!" : "❌ Noto'g'ri"}
              </div>
              {!isCorrect && <div style={{ fontSize:13, color:T.textMuted }}>To’g’risi: <span style={{ color:T.gold, fontWeight:600 }}>{correct}</span></div>}
            </div>
          )}

          <div style={{ display:"flex", gap:10, marginTop:12 }}>
            {!checked ? (
              <button onClick={checkAnswer} disabled={!answer.trim()}
                style={{ flex:1, background:answer.trim()?T.gradient:"rgba(255,255,255,0.1)", border:"none", borderRadius:12, padding:"14px 0", color:"#fff", fontWeight:700, fontSize:15, cursor:answer.trim()?"pointer":"not-allowed" }}>
                ✓ Tekshirish
              </button>
            ) : (
              <button onClick={next}
                style={{ flex:1, background:T.gradient, border:"none", borderRadius:12, padding:"14px 0", color:"#fff", fontWeight:700, fontSize:15, cursor:"pointer" }}>
                Keyingi →
              </button>
            )}
          </div>
        </div>
      )}

      {/* WORD ORDER */}
      {mode === "order" && (
        <div>
          <div style={{ background:T.card, borderRadius:14, padding:16, border:`1px solid ${T.border}`, marginBottom:12 }}>
            <div style={{ fontSize:12, color:T.gold, fontWeight:700, marginBottom:8 }}>💡 Yordam: {item.hint}</div>
            <div style={{ minHeight:48, background:T.bg, borderRadius:10, padding:"10px 12px", marginBottom:12, fontSize:18, fontWeight:700, color:orderCorrect?T.green:T.text, display:"flex", flexWrap:"wrap", gap:8, alignItems:"center" }}>
              {orderSel.length===0 ? <span style={{ color:T.textMuted, fontSize:14 }}>So’zlarni tartibda tanlang...</span> : orderSel.join(" ")}
              {orderCorrect && <span style={{ color:T.green }}>✅</span>}
            </div>
            <div style={{ display:"flex", flexWrap:"wrap", gap:8 }}>
              {shuffledWords.map((w,i)=>{
                const used = orderSel.includes(w);
                return (
                  <button key={i} onClick={()=>handleOrderTap(w)}
                    style={{ padding:"10px 16px", borderRadius:10, border:`2px solid ${used?T.red:T.border}`, background:used?"rgba(230,57,70,0.15)":T.card, color:used?T.red:T.text, fontSize:16, fontWeight:700, cursor:"pointer", opacity:used?0.5:1, transition:"all 0.2s" }}>
                    {w}
                  </button>
                );
              })}
            </div>
            {orderSel.length>0 && !orderCorrect && (
              <button onClick={()=>setOrderSel([])}
                style={{ marginTop:10, background:"none", border:`1px solid ${T.border}`, borderRadius:8, padding:"6px 14px", color:T.textMuted, fontSize:12, cursor:"pointer" }}>
                🔄 Tozalash
              </button>
            )}
          </div>
          {orderCorrect ? (
            <button onClick={next}
              style={{ width:"100%", background:T.gradient, border:"none", borderRadius:12, padding:"14px 0", color:"#fff", fontWeight:700, fontSize:15, cursor:"pointer" }}>
              Keyingi →
            </button>
          ) : (
            <div style={{ textAlign:"center", fontSize:12, color:T.textMuted }}>So'zlarni to'g'ri tartibda tanlang ({idx+1}/{items.length})</div>
          )}
        </div>
      )}
    </div>
  );
}

