          <div style={{ fontSize:13, color:T.red, fontWeight:700, marginBottom:10 }}>🔍 Gapdagi xatoni toping:</div>
          <div style={{ fontSize:20, fontWeight:700, color:T.text, marginBottom:14, background:T.bg, borderRadius:10, padding:"12px 14px" }}>{item.sentence}</div>
          {[item.error, "Xato yo'q", item.correct.slice(0,5), "Hammasi to'g'ri"].map((opt,i)=>{
            const isAns=i===0; let bg=T.bg, border=T.border, color=T.text;
            if(sel!==null){if(isAns){bg="rgba(86,207,114,0.2)";border=T.green;color=T.green;}else if(i===sel){bg="rgba(230,57,70,0.2)";border=T.red;color=T.red;}}
            return <button key={i} onClick={()=>{if(sel!==null)return;setSel(i);setTotal(t=>t+1);if(isAns)setScore(s=>s+1);setTimeout(next,1100);}} style={{ width:"100%", background:bg, border:`2px solid ${border}`, borderRadius:10, padding:"11px 14px", color, fontSize:14, fontWeight:600, cursor:"pointer", marginBottom:8, textAlign:"left", transition:"all 0.2s" }}>{opt}</button>;
          })}
          {sel!==null && <div style={{ background:"rgba(86,207,114,0.1)", borderRadius:10, padding:"10px 14px", fontSize:13, color:T.green }}>✅ To’g’ri: <strong>{item.correct}</strong><br/><span style={{ color:T.textMuted, fontSize:12 }}>💡 {item.exp}</span></div>}
        </div>
      )}
      {mode==="order" && item && (
        <div style={{ background:T.card, borderRadius:14, padding:16, border:`1px solid ${T.border}` }}>
          <div style={{ fontSize:12, color:T.gold, fontWeight:700, marginBottom:8 }}>💡 {item.hint}</div>
          <div style={{ minHeight:52, background:T.bg, borderRadius:10, padding:"10px 12px", marginBottom:12, fontSize:20, fontWeight:700, display:"flex", flexWrap:"wrap", gap:6, alignItems:"center", border:`1px solid ${orderCorrect?T.green:T.border}` }}>
            {orderSel.length===0?<span style={{ color:T.textMuted, fontSize:13 }}>So’zlarni tartibda bosing...</span>:orderSel.map((w,i)=><button key={i} onClick={()=>setOrderSel(s=>s.filter((_,j)=>j!==i))} style={{ background:"rgba(230,57,70,0.15)", border:`1px solid ${T.red}`, borderRadius:8, padding:"4px 12px", color:T.red, fontSize:18, fontWeight:700, cursor:"pointer" }}>{w}</button>)}
            {orderCorrect&&<span style={{ color:T.green }}>✅</span>}
          </div>
          <div style={{ display:"flex", flexWrap:"wrap", gap:8, marginBottom:12 }}>
            {(item.words||[]).map((w,i)=>{const ok=orderSel.filter(x=>x===w).length<(item.words||[]).filter(x=>x===w).length;return <button key={i} onClick={()=>{if(ok)setOrderSel(s=>[...s,w]);}} style={{ padding:"10px 16px", borderRadius:10, border:`1px solid ${T.border}`, background:ok?T.bg:"rgba(0,0,0,0.3)", color:ok?T.text:T.textMuted, fontSize:18, fontWeight:700, cursor:ok?"pointer":"default", opacity:ok?1:0.4 }}>{w}</button>;})}
          </div>
          <div style={{ display:"flex", gap:8 }}>
            <button onClick={()=>setOrderSel([])} style={{ flex:1, background:T.bg, border:`1px solid ${T.border}`, borderRadius:10, padding:"10px 0", color:T.textMuted, fontSize:13, cursor:"pointer" }}>🔄 Tozalash</button>
            {orderCorrect&&<button onClick={()=>{setIdx(i=>(i+1)%items.length);setOrderSel([]);}} style={{ flex:1, background:T.gradient, border:"none", borderRadius:10, padding:"10px 0", color:"#fff", fontWeight:700, cursor:"pointer" }}>Keyingi →</button>}
          </div>
          <div style={{ marginTop:8, fontSize:11, color:T.textMuted, textAlign:"center" }}>{idx+1}/{items.length}</div>
        </div>
      )}
    </div>
  );
}

