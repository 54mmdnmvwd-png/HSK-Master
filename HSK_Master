// AUTH SCREEN — PIN (Founder) + O'quvchi kirish
// ============================================================
const FOUNDER_PIN = "2024"; // Sabrina uchun maxfiy PIN

function AuthScreen({ onLogin }) {
  const [mode, setMode] = useState("main"); // main | founder | student
  const [pin, setPin] = useState("");
  const [pinError, setPinError] = useState("");
  const [stuName, setStuName] = useState("");
  const [stuError, setStuError] = useState("");

  const handlePinPress = (digit) => {
    if (pin.length >= 4) return;
    const next = pin + digit;
    setPin(next);
    setPinError("");
    if (next.length === 4) {
      setTimeout(() => {
        if (next === FOUNDER_PIN) {
          const u = { name: "Sabrina", role: "founder" };
          storage.set("hsk_user", u);
          onLogin(u);
        } else {
          setPinError("PIN noto'g'ri!");
          setPin("");
        }
      }, 200);
    }
  };

  const handleStudentLogin = () => {
    if (!stuName.trim()) return setStuError("Ismingizni kiriting");
    const u = { name: stuName.trim(), role: "student" };
    storage.set("hsk_user", u);
    onLogin(u);
  };

  // PIN dots
  const PinDots = () => (
    <div style={{ display: "flex", gap: 14, justifyContent: "center", margin: "24px 0 8px" }}>
      {[0,1,2,3].map(i => (
        <div key={i} style={{ width: 18, height: 18, borderRadius: "50%", background: i < pin.length ? T.red : "transparent", border: `2px solid ${i < pin.length ? T.red : T.textMuted}`, transition: "all 0.2s" }} />
      ))}
    </div>
  );

  // Numpad
  const Numpad = () => (
    <div style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: 12, marginTop: 16 }}>
      {["1","2","3","4","5","6","7","8","9","","0","⌫"].map((d, i) => (
        <button key={i} onClick={() => {
          if (d === "⌫") { setPin(p => p.slice(0,-1)); setPinError(""); }
          else if (d) handlePinPress(d);
        }}
          style={{ padding: "18px 0", borderRadius: 14, border: `1px solid ${T.border}`, background: d === "⌫" ? "rgba(230,57,70,0.1)" : T.card, color: d === "⌫" ? T.red : T.text, fontSize: d === "⌫" ? 20 : 24, fontWeight: 700, cursor: d ? "pointer" : "default", opacity: d ? 1 : 0 }}>
          {d}
        </button>
      ))}
    </div>
  );

  return (
    <div style={{ minHeight: "100vh", display: "flex", alignItems: "center", justifyContent: "center", padding: 24, background: T.bg, position: "relative" }}>
      <div style={{ position: "absolute", top: 0, left: 0, right: 0, height: 300, background: "radial-gradient(ellipse at 50% -20%, rgba(230,57,70,0.2) 0%, transparent 70%)" }} />

      <div style={{ width: "100%", maxWidth: 380, position: "relative", zIndex: 1 }}>
        {/* Logo */}
        <div style={{ textAlign: "center", marginBottom: 32 }}>
          <div style={{ fontSize: 52, fontWeight: 900, lineHeight: 1 }}><span style={{ color: T.red }}>HSK</span><span style={{ color: T.gold }}>1</span></div>
          <div style={{ fontSize: 28, fontWeight: 900, letterSpacing: 6, color: T.text, marginBottom: 4 }}>MASTER</div>
          <div style={{ fontSize: 12, color: T.textMuted, letterSpacing: 2 }}>汉语学习平台</div>
        </div>

        {/* MAIN — ikki tugma */}
        {mode === "main" && (
          <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
            <button onClick={() => setMode("founder")}
              style={{ width: "100%", background: T.gradient, border: "none", borderRadius: 16, padding: "18px 0", color: "#fff", fontWeight: 800, fontSize: 17, cursor: "pointer", letterSpacing: 1 }}>
              👩‍🏫 Founder kirishi
            </button>
            <button onClick={() => setMode("student")}
              style={{ width: "100%", background: T.card, border: `1px solid ${T.border}`, borderRadius: 16, padding: "18px 0", color: T.text, fontWeight: 700, fontSize: 17, cursor: "pointer" }}>
              🎓 O'quvchi kirishi
            </button>
            <div style={{ textAlign: "center", marginTop: 8, fontSize: 12, color: T.textMuted }}>
              by <span style={{ color: T.gold, fontWeight: 700 }}>Ro’zmatova Sabrina Ashurmatovna</span>
            </div>
          </div>
        )}

        {/* FOUNDER — PIN */}
        {mode === "founder" && (
          <div style={{ background: T.card, borderRadius: 20, padding: 28, border: `1px solid ${T.border}` }}>
            <div style={{ textAlign: "center" }}>
              <div style={{ fontSize: 40, marginBottom: 8 }}>🔐</div>
              <div style={{ fontSize: 18, fontWeight: 800, color: T.gold }}>Founder PIN</div>
              <div style={{ fontSize: 13, color: T.textMuted, marginTop: 4 }}>4 xonali PIN kiriting</div>
              <PinDots />
              {pinError && <div style={{ color: T.red, fontSize: 13, marginTop: 4 }}>{pinError}</div>}
            </div>
            <Numpad />
            <button onClick={() => { setMode("main"); setPin(""); setPinError(""); }}
              style={{ width: "100%", background: "none", border: "none", color: T.textMuted, fontSize: 13, cursor: "pointer", marginTop: 16 }}>
              ← Orqaga
            </button>
          </div>
        )}

        {/* STUDENT — Ism bilan */}
        {mode === "student" && (
          <div style={{ background: T.card, borderRadius: 20, padding: 28, border: `1px solid ${T.border}` }}>
            <div style={{ textAlign: "center", marginBottom: 24 }}>
              <div style={{ fontSize: 40, marginBottom: 8 }}>🎓</div>
              <div style={{ fontSize: 18, fontWeight: 800, color: T.text }}>O’quvchi kirishi</div>
              <div style={{ fontSize: 13, color: T.textMuted, marginTop: 4 }}>Ismingizni kiriting</div>
            </div>
            <input value={stuName} onChange={e => { setStuName(e.target.value); setStuError(""); }}
              placeholder="Ismingiz (masalan: Aziz)"
              style={{ width: "100%", background: T.bg, border: `1px solid ${stuError ? T.red : T.border}`, borderRadius: 12, padding: "14px 16px", color: T.text, fontSize: 16, boxSizing: "border-box", outline: "none", marginBottom: 4 }} />
            {stuError && <div style={{ color: T.red, fontSize: 12, marginBottom: 8 }}>{stuError}</div>}
            <button onClick={handleStudentLogin}
              style={{ width: "100%", background: T.gradient, border: "none", borderRadius: 12, padding: "15px 0", color: "#fff", fontWeight: 800, fontSize: 16, cursor: "pointer", marginTop: 14 }}>
              Kirish →
            </button>
            <button onClick={() => { setMode("main"); setStuName(""); setStuError(""); }}
              style={{ width: "100%", background: "none", border: "none", color: T.textMuted, fontSize: 13, cursor: "pointer", marginTop: 12 }}>
              ← Orqaga
            </button>
          </div>
        )}
      </div>
    </div>
  );
}

