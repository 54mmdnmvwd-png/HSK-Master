// TEST GAME
// ============================================================
function TestGame({ words: W = HSK1_WORDS, onBack, onXP }) {
  const [mode, setMode] = useState(null);
  const [idx, setIdx] = useState(0);
  const [score, setScore] = useState(0);
  const [answered, setAnswered] = useState(null);
  const [finished, setFinished] = useState(false);
  const TOTAL = Math.min(10, W.length);

  const questions = useMemo(() => {
    if (!mode) return [];
    return [...W].sort(() => Math.random() - 0.5).slice(0, TOTAL).map(w => {
      const wrong = HSK1_WORDS.filter(x => x.id !== w.id).sort(() => Math.random() - 0.5).slice(0, 3);
      if (mode === "hz2uz") return { q: w.hanzi, correctAns: w.uzbek, opts: [w.uzbek, ...wrong.map(x => x.uzbek)].sort(() => Math.random() - 0.5) };
      if (mode === "uz2hz") return { q: w.uzbek, correctAns: w.hanzi, opts: [w.hanzi, ...wrong.map(x => x.hanzi)].sort(() => Math.random() - 0.5) };
      return { q: w.pinyin, correctAns: w.hanzi, opts: [w.hanzi, ...wrong.map(x => x.hanzi)].sort(() => Math.random() - 0.5) };
    });
  }, [mode, W]);

  if (!mode) return (
    <div style={{ height: "100vh", display: "flex", flexDirection: "column" }}>
      <div style={{ background: T.gradient, padding: "52px 16px 16px", display: "flex", alignItems: "center", gap: 12 }}>
        <button onClick={onBack} style={{ background: "rgba(0,0,0,0.2)", border: "none", borderRadius: 10, width: 36, height: 36, color: "#fff", fontSize: 20, cursor: "pointer" }}>‹</button>
        <div style={{ fontSize: 16, fontWeight: 700, color: "#fff" }}>Test rejimi</div>
      </div>
      <div style={{ flex: 1, padding: 24, display: "flex", flexDirection: "column", gap: 14 }}>
        {[["hz2uz","🀄 → O'zbek","Hanzi ko'rib o'zbekcha top"],["uz2hz","O'zbek → 🀄","O'zbekcha ko'rib hanzi top"],["py2hz","Pinyin → 🀄","Pinyin ko'rib hanzi top"]].map(([id,title,desc]) => (
          <button key={id} onClick={() => setMode(id)}
            style={{ background: T.card, border: `1px solid ${T.border}`, borderRadius: 16, padding: "20px 18px", cursor: "pointer", textAlign: "left" }}>
            <div style={{ fontSize: 20, fontWeight: 800, color: T.text, marginBottom: 6 }}>{title}</div>
            <div style={{ fontSize: 13, color: T.textMuted }}>{desc}</div>
          </button>
        ))}
      </div>
    </div>
  );

  if (finished) return <ResultScreen score={score} total={TOTAL} onBack={() => { setMode(null); setIdx(0); setScore(0); setAnswered(null); setFinished(false); }} onExit={onBack} />;

  const cur = questions[idx];
  const handleAns = (opt) => {
    if (answered !== null) return;
    setAnswered(opt);
    if (opt === cur.correctAns) setScore(s => s + 1);
    setTimeout(() => {
      if (idx + 1 >= TOTAL) { setFinished(true); onXP && onXP(15); }
      else { setIdx(i => i + 1); setAnswered(null); }
    }, 700);
  };

  return (
    <div style={{ height: "100vh", display: "flex", flexDirection: "column" }}>
      <GameHeader title="Test" score={score} idx={idx} total={TOTAL} onBack={onBack} />
      <div style={{ flex: 1, display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", padding: 24 }}>
        <div style={{ fontSize: cur.q.length <= 4 ? 64 : 24, fontWeight: 900, color: T.text, marginBottom: 32, textAlign: "center" }}>{cur.q}</div>
        <div style={{ width: "100%", display: "flex", flexDirection: "column", gap: 10 }}>
          {cur.opts.map((opt, i) => {
            let bg = T.card, border = T.border, color = T.text;
            if (answered !== null) {
              if (opt === cur.correctAns) { bg = "rgba(86,207,114,0.2)"; border = T.green; color = T.green; }
              else if (opt === answered && opt !== cur.correctAns) { bg = "rgba(230,57,70,0.2)"; border = T.red; color = T.red; }
            }
            return (
              <button key={i} onClick={() => handleAns(opt)}
                style={{ background: bg, border: `2px solid ${border}`, borderRadius: 14, padding: "16px 18px", color, fontSize: 16, fontWeight: 700, cursor: "pointer", textAlign: "left", transition: "all 0.2s" }}>
                {opt}
              </button>
            );
          })}
        </div>
      </div>
    </div>
  );
}

