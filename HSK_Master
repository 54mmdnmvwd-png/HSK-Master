// LISTENING SECTION
// ============================================================
function ListeningSection({ data }) {
  const [mode, setMode] = useState("dialog"); // dialog | fill
  const [dIdx, setDIdx] = useState(0);
  const [qIdx, setQIdx] = useState(0);
  const [selected, setSelected] = useState(null);
  const [score, setScore] = useState(0);
  const [done, setDone] = useState(false);
  const [fillSel, setFillSel] = useState({});
  const [fillChecked, setFillChecked] = useState(false);
  const [showAll, setShowAll] = useState(false);

  const speak = (text) => { if ("speechSynthesis" in window) { const u = new SpeechSynthesisUtterance(text); u.lang = "zh-CN"; u.rate = 0.75; speechSynthesis.speak(u); } };
  const speakAll = (lines) => { speechSynthesis.cancel(); lines.forEach((l, i) => { const u = new SpeechSynthesisUtterance(l.zh); u.lang = "zh-CN"; u.rate = 0.75; u.onstart = () => {}; speechSynthesis.speak(u); }); };

  const dialog = data.dialogs[dIdx];
  const resetQ = () => { setQIdx(0); setSelected(null); setScore(0); setDone(false); };

  return (
    <div>
      <div style={{ display: "flex", gap: 8, marginBottom: 16 }}>
        {[["dialog","🎧 Dialog"],["fill","✏️ O'yin"]].map(([id,label]) => (
          <button key={id} onClick={() => { setMode(id); resetQ(); setFillSel({}); setFillChecked(false); }}
            style={{ flex: 1, padding: "10px 6px", borderRadius: 10, border: `1px solid ${mode===id?T.red:T.border}`, background: mode===id?"rgba(230,57,70,0.15)":T.card, color: mode===id?T.red:T.textMuted, fontSize: 12, fontWeight: mode===id?700:400, cursor: "pointer" }}>
            {label}
          </button>
        ))}
      </div>

      {/* DIALOG MODE */}
      {mode === "dialog" && (
        <div>
          {/* Dialog tabs */}
          <div style={{ display: "flex", gap: 6, marginBottom: 12 }}>
            {data.dialogs.map((d, i) => (
              <button key={i} onClick={() => { setDIdx(i); resetQ(); }}
                style={{ flex: 1, padding: "8px 6px", borderRadius: 8, border: `1px solid ${dIdx===i?T.gold:T.border}`, background: dIdx===i?"rgba(244,196,48,0.15)":T.card, color: dIdx===i?T.gold:T.textMuted, fontSize: 11, cursor: "pointer", fontWeight: dIdx===i?700:400 }}>
                {d.title}
              </button>
            ))}
          </div>

          <div style={{ background: T.card, borderRadius: 14, padding: 16, border: `1px solid ${T.border}`, marginBottom: 12 }}>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 12 }}>
              <div style={{ fontSize: 14, fontWeight: 700, color: T.gold }}>{dialog.title}</div>
              <div style={{ display: "flex", gap: 8 }}>
                <button onClick={() => speakAll(dialog.lines)}
                  style={{ background: "rgba(79,195,247,0.15)", border: "none", borderRadius: 8, padding: "6px 12px", color: T.blue, fontSize: 12, cursor: "pointer" }}>▶ Hammasi</button>
                <button onClick={() => setShowAll(p=>!p)}
                  style={{ background: T.bg, border: `1px solid ${T.border}`, borderRadius: 8, padding: "6px 12px", color: T.textMuted, fontSize: 12, cursor: "pointer" }}>{showAll?"Yashir":"Ko'rsat"}</button>
              </div>
            </div>
            {dialog.lines.map((line, i) => (
              <div key={i} style={{ display: "flex", alignItems: "flex-start", gap: 10, marginBottom: 12 }}>
                <div style={{ minWidth: 52, fontSize: 11, color: i%2===0?T.red:T.gold, fontWeight: 700, paddingTop: 2 }}>{line.speaker}</div>
                <div style={{ flex: 1, background: T.bg, borderRadius: 10, padding: "10px 12px" }}>
                  <div style={{ fontSize: 15, color: T.text, fontWeight: 600 }}>{line.zh}</div>
                  {showAll && <>
                    <div style={{ fontSize: 12, color: T.blue, marginTop: 3 }}>{line.py}</div>
                    <div style={{ fontSize: 13, color: T.textMuted, marginTop: 3 }}>{line.uz}</div>
                  </>}
                </div>
                <button onClick={() => speak(line.zh)} style={{ background: "none", border: "none", fontSize: 18, cursor: "pointer", paddingTop: 4 }}>🔊</button>
              </div>
            ))}
          </div>

          {/* Dialog questions */}
          <div style={{ background: T.card, borderRadius: 14, padding: 16, border: `1px solid ${T.border}` }}>
            <div style={{ fontSize: 13, fontWeight: 700, color: T.gold, marginBottom: 12 }}>❓ Savollar:</div>
            {!done ? (
              <>
                <div style={{ fontSize: 12, color: T.textMuted, marginBottom: 10 }}>{qIdx+1}/{dialog.questions.length}</div>
                <div style={{ fontSize: 15, fontWeight: 700, color: T.text, marginBottom: 14 }}>{dialog.questions[qIdx].q}</div>
                {dialog.questions[qIdx].opts.map((opt, i) => {
                  let bg = T.bg, border = T.border, color = T.text;
                  if (selected !== null) {
                    if (i === dialog.questions[qIdx].ans) { bg = "rgba(86,207,114,0.2)"; border = T.green; color = T.green; }
                    else if (i === selected) { bg = "rgba(230,57,70,0.2)"; border = T.red; color = T.red; }
                  }
                  return (
                    <button key={i} onClick={() => {
                      if (selected !== null) return;
                      setSelected(i);
                      if (i === dialog.questions[qIdx].ans) setScore(s=>s+1);
                      setTimeout(() => {
                        if (qIdx+1 >= dialog.questions.length) setDone(true);
                        else { setQIdx(q=>q+1); setSelected(null); }
                      }, 700);
                    }}
                      style={{ width: "100%", background: bg, border: `2px solid ${border}`, borderRadius: 12, padding: "12px 14px", color, fontSize: 15, fontWeight: 600, cursor: "pointer", marginBottom: 8, textAlign: "left", transition: "all 0.2s" }}>
                      {opt}
                    </button>
                  );
                })}
              </>
            ) : (
              <div style={{ textAlign: "center", padding: 16 }}>
                <div style={{ fontSize: 36, marginBottom: 8 }}>{score === dialog.questions.length?"🏆":"⭐"}</div>
                <div style={{ fontSize: 22, fontWeight: 900, color: T.gold }}>{score}/{dialog.questions.length}</div>
                <button onClick={resetQ} style={{ marginTop: 16, background: T.gradient, border: "none", borderRadius: 10, padding: "10px 24px", color: "#fff", fontWeight: 700, cursor: "pointer" }}>🔄 Qayta</button>
              </div>
            )}
          </div>
        </div>
      )}

      {/* FILL AUDIO GAME */}
      {mode === "fill" && (
        <div>
          <div style={{ background: T.card, borderRadius: 14, padding: 16, border: `1px solid ${T.border}`, marginBottom: 12 }}>
            <div style={{ fontSize: 14, fontWeight: 700, color: T.gold, marginBottom: 4 }}>🎯 To’g’ri so’zni tanlang</div>
            <div style={{ fontSize: 12, color: T.textMuted, marginBottom: 16 }}>Bo’sh joyga mos keladiganini bosing</div>
            {data.fillAudio.map((item, i) => {
              const sel = fillSel[i];
              const isCorrect = fillChecked && sel === item.correct;
              const isWrong = fillChecked && sel && sel !== item.correct;
              return (
                <div key={i} style={{ marginBottom: 16, background: T.bg, borderRadius: 12, padding: 14 }}>
                  <div style={{ fontSize: 20, fontWeight: 700, color: T.text, marginBottom: 10, display: "flex", alignItems: "center", gap: 8 }}>
                    <button onClick={() => speak(item.zh.replace("___", item.correct))} style={{ background: "none", border: "none", fontSize: 18, cursor: "pointer" }}>🔊</button>
                    {item.zh.replace("___", sel ? `[${sel}]` : "___")}
                    {fillChecked && <span>{isCorrect?"✅":"❌"}</span>}
                  </div>
                  <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
                    {item.options.map((opt, j) => {
                      let bg = T.card, border = T.border, color = T.text;
                      if (fillChecked) {
                        if (opt === item.correct) { bg = "rgba(86,207,114,0.2)"; border = T.green; color = T.green; }
                        else if (opt === sel) { bg = "rgba(230,57,70,0.2)"; border = T.red; color = T.red; }
                      } else if (sel === opt) { bg = "rgba(244,196,48,0.15)"; border = T.gold; color = T.gold; }
                      return (
                        <button key={j} onClick={() => !fillChecked && setFillSel(f=>({...f,[i]:opt}))}
                          style={{ padding: "8px 16px", borderRadius: 8, border: `2px solid ${border}`, background: bg, color, fontSize: 18, fontWeight: 700, cursor: "pointer", transition: "all 0.2s" }}>
                          {opt}
                        </button>
                      );
                    })}
                  </div>
                </div>
              );
            })}
          </div>
          {!fillChecked ? (
            <button onClick={() => setFillChecked(true)}
              style={{ width: "100%", background: T.gradient, border: "none", borderRadius: 12, padding: "13px", color: "#fff", fontWeight: 700, fontSize: 15, cursor: "pointer" }}>✓ Tekshirish</button>
          ) : (
            <button onClick={() => { setFillSel({}); setFillChecked(false); }}
              style={{ width: "100%", background: T.card, border: `1px solid ${T.border}`, borderRadius: 12, padding: "13px", color: T.text, fontWeight: 700, fontSize: 15, cursor: "pointer" }}>🔄 Qayta</button>
          )}
        </div>
      )}
    </div>
  );
}

// ============================================================
// DICTIONARY
// ============================================================
function DictionaryScreen() {
  const [query, setQuery] = useState("");
  const [selected, setSelected] = useState(null);
  const filtered = useMemo(() => {
    if (!query.trim()) return HSK1_WORDS;
    const q = query.toLowerCase();
    return HSK1_WORDS.filter(w => w.hanzi.includes(q) || w.pinyin.toLowerCase().includes(q) || w.uzbek.toLowerCase().includes(q));
  }, [query]);

  return (
    <div style={{ height: "100vh", display: "flex", flexDirection: "column" }}>
      <div style={{ background: "linear-gradient(160deg, #1a1a3e 0%, #0a0a1a 100%)", padding: "52px 16px 16px", flexShrink: 0 }}>
        <div style={{ fontSize: 20, fontWeight: 900, color: T.text, marginBottom: 12 }}>📖 Lug’at · HSK 1</div>
        <div style={{ position: "relative" }}>
          <span style={{ position: "absolute", left: 12, top: "50%", transform: "translateY(-50%)", fontSize: 16 }}>🔍</span>
          <input value={query} onChange={e => setQuery(e.target.value)} placeholder="Hanzi, pinyin yoki o'zbekcha..."
            style={{ width: "100%", background: T.card, border: `1px solid ${T.border}`, borderRadius: 12, padding: "12px 12px 12px 38px", color: T.text, fontSize: 14, boxSizing: "border-box", outline: "none" }} />
        </div>
        <div style={{ fontSize: 12, color: T.textMuted, marginTop: 8 }}>{filtered.length} ta so'z</div>
      </div>
      {selected ? (
        <WordDetail word={selected} onBack={() => setSelected(null)} />
      ) : (
        <div style={{ flex: 1, overflowY: "auto", padding: "8px 16px 80px" }}>
          {HSK1_WORDS.length === 0 ? (
            <EmptyState icon="📖" text="Lug'at tez kunda to'ldiriladi.\nDOCX faylni yuboring!" />
          ) : filtered.map(w => (
            <button key={w.id} onClick={() => setSelected(w)}
              style={{ width: "100%", background: T.card, border: `1px solid ${T.border}`, borderRadius: 12, padding: "14px 16px", marginBottom: 8, display: "flex", alignItems: "center", gap: 14, cursor: "pointer", textAlign: "left" }}>
              <div style={{ fontSize: 36, fontWeight: 900, color: T.text, minWidth: 50, textAlign: "center" }}>{w.hanzi}</div>
              <div style={{ flex: 1 }}>
                <div style={{ fontSize: 14, color: T.textMuted }}>{w.pinyin}</div>
                <div style={{ fontSize: 16, fontWeight: 700, color: T.text, marginTop: 2 }}>{w.uzbek}</div>
              </div>
              {w.pos && <div style={{ fontSize: 11, background: "rgba(230,57,70,0.15)", color: T.red, borderRadius: 6, padding: "3px 8px" }}>{w.pos}</div>}
            </button>
          ))}
        </div>
      )}
    </div>
  );
}

