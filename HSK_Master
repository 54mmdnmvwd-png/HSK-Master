        <div style={{ fontSize: 20, fontWeight: 900, color: T.text }}>文 Grammatika · HSK 1</div>
        <div style={{ fontSize: 13, color: T.textMuted, marginTop: 4 }}>O’zbekcha izoh bilan</div>
      </div>
      <div style={{ flex: 1, overflowY: "auto", padding: "8px 16px 80px" }}>
        {HSK1_GRAMMAR.length === 0 ? <EmptyState icon="文" text="Grammatika qoidalari tez kunda qo'shiladi" /> : HSK1_GRAMMAR.map(g => <GrammarCard key={g.id} grammar={g} />)}
      </div>
