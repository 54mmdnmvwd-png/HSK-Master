// ============================================================
// MAIN APP
// ============================================================
export default function App() {
  const [screen, setScreen] = useState("splash");
  const [user, setUser] = useState(null);
  const [nav, setNav] = useState("home");
  const [selectedLesson, setSelectedLesson] = useState(null);
  const [stats, setStats] = useState(() => storage.get("hsk1_stats", {
    xp: 0, streak: 0, lastActive: null, lessonsCompleted: 0, completedLessons: [], activeDays: [], avgScore: null, gamesPlayed: 0, totalCorrect: 0
  }));

  // Streak hisoblash — har kun kirganida
  useEffect(() => {
    const saved = storage.get("hsk_user", null);
    if (saved) { setUser(saved); setScreen("app"); }
  }, []);

  useEffect(() => {
    if (!user) return;
    const today = new Date().toDateString();
    if (stats.lastActive === today) return; // Bugun allaqachon hisoblangan

    const yesterday = new Date(Date.now() - 86400000).toDateString();
    const newStreak = stats.lastActive === yesterday ? (stats.streak || 0) + 1 : 1;
    const todayIdx = new Date().getDay() === 0 ? 6 : new Date().getDay() - 1;
    const newActiveDays = [...new Set([...(stats.activeDays||[]), todayIdx])];

    const updated = { ...stats, streak: newStreak, lastActive: today, activeDays: newActiveDays };
    setStats(updated);
    storage.set("hsk1_stats", updated);
  }, [user]);

  const addXP = useCallback((amount) => {
    setStats(prev => {
      const updated = {
        ...prev,
        xp: (prev.xp || 0) + amount,
        gamesPlayed: (prev.gamesPlayed || 0) + 1,
      };
      storage.set("hsk1_stats", updated);
      return updated;
    });
  }, []);

  if (screen === "splash") return <SplashScreen onDone={() => setScreen("auth")} />;
  if (screen === "auth") return <AuthScreen onLogin={u => { setUser(u); setScreen("app"); }} />;

  return (
    <div style={{ fontFamily: "'Segoe UI','PingFang SC',sans-serif", background: T.bg, color: T.text, minHeight: "100vh", maxWidth: 430, margin: "0 auto", position: "relative" }}>
      {selectedLesson ? (
        <LessonDetailScreen lesson={selectedLesson} onBack={() => setSelectedLesson(null)} />
      ) : (
        <>
          {nav === "home" && <HomeScreen user={user} stats={stats} onNavigate={setNav} />}
          {nav === "lessons" && <LessonsScreen stats={stats} onSelectLesson={setSelectedLesson} />}
          {nav === "dictionary" && <DictionaryScreen />}
          {nav === "grammar" && <GrammarScreen />}
          {nav === "categories" && <CategoriesScreen />}
          {nav === "games" && <GamesScreen onXP={addXP} />}
          <BottomNav active={nav} onChange={setNav} />
        </>
      )}
    </div>
  );
}

