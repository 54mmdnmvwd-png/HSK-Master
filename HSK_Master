function GrammarExercises({ lessonId }) {
  const exData = GRAMMAR_EXERCISES[lessonId];
  const [mode, setMode] = useState("choose");
  const [idx, setIdx] = useState(0);
  const [sel, setSel] = useState(null);
  const [score, setScore] = useState(0);
  const [total, setTotal] = useState(0);
  const [matchSel, setMatchSel] = useState(null);
  const [matched, setMatched] = useState([]);
  const [orderSel, setOrderSel] = useState([]);
  if (!exData) return <EmptyState icon="✏️" text="Tez kunda qo'shiladi" />;
  const items = exData[mode] || [];
  const item = items[idx % Math.max(items.length, 1)];
  const next = () => { setIdx(i=>(i+1)%items.length); setSel(null); setOrderSel([]); };
  const handleQ = (i) => { if (sel !== null) return; setSel(i); setTotal(t=>t+1); if (i === item.ans) setScore(s=>s+1); setTimeout(next, 1100); };
  const leftItems = exData.match?.slice(0,6) || [];
  const rightItems = useMemo(() => [...(exData.match?.slice(0,6)||[])].sort(()=>Math.random()-0.5), [lessonId]);
  const handleMatchL = (i) => { if (matched.some(m=>m.l===i)) return; setMatchSel(s => s?.type==="l" && s.i===i ? null : { type:"l", i }); };
  const handleMatchR = (i) => { if (matched.some(m=>m.r===i)) return; if (!matchSel || matchSel.type!=="l") { setMatchSel({ type:"r", i }); return; } if (leftItems[matchSel.i]?.zh === rightItems[i]?.zh) { setMatched(m=>[...m,{ l:matchSel.i, r:i }]); setScore(s=>s+1); setTotal(t=>t+1); } setMatchSel(null); };
  const orderCorrect = item?.correct && orderSel.join("") === item.correct.replace(/[。！？，]/g,"");
  const modeColors = { choose:T.blue, fill:T.gold, match:T.green, error:T.red, order:"#a29bfe" };
  const mc = modeColors[mode] || T.blue;
  const btnStyle = (i) => { let bg=T.bg, border=T.border, color=T.text; if (sel!==null){if(i===item.ans){bg="rgba(86,207,114,0.2)";border=T.green;color=T.green;}else if(i===sel){bg="rgba(230,57,70,0.2)";border=T.red;color=T.red;}} return { width:"100%", background:bg, border:`2px solid ${border}`, borderRadius:10, padding:"12px 14px", color, fontSize:14, fontWeight:600, cursor:"pointer", marginBottom:8, textAlign:"left", transition:"all 0.2s" }; };
  return (
    <div>
      {total > 0 && mode!=="match" && <div style={{ display:"flex", justifyContent:"space-between", marginBottom:10 }}><span style={{ fontSize:12, color:T.textMuted }}>{idx+1}/{items.length}</span><span style={{ fontSize:13, fontWeight:700, color:T.gold }}>✓ {score}/{total}</span></div>}
      <div style={{ display:"flex", gap:6, marginBottom:14, overflowX:"auto", paddingBottom:4 }}>
        {[["choose","❓ Savol"],["fill","✏️ To'ldirish"],["match","🔗 Juftlashtir"],["error","🔍 Xatoni top"],["order","🔀 Tartibla"]].map(([id,label])=>(
          <button key={id} onClick={()=>{setMode(id);setIdx(0);setSel(null);setMatchSel(null);setMatched([]);setOrderSel([]);}}
            style={{ padding:"8px 12px", borderRadius:10, border:`1px solid ${mode===id?modeColors[id]:T.border}`, background:mode===id?`${modeColors[id]}20`:T.card, color:mode===id?modeColors[id]:T.textMuted, fontSize:11, fontWeight:mode===id?700:400, cursor:"pointer", whiteSpace:"nowrap", flexShrink:0 }}>
            {label}
          </button>
        ))}
      </div>
      {(mode==="choose"||mode==="fill") && item && (
        <div style={{ background:T.card, borderRadius:14, padding:16, border:`1px solid ${T.border}` }}>
          <div style={{ fontSize:mode==="fill"?20:15, fontWeight:700, color:T.text, marginBottom:16, textAlign:mode==="fill"?"center":"left" }}>{item.q}</div>
          {item.opts.map((opt,i) => <button key={i} onClick={()=>handleQ(i)} style={btnStyle(i)}>{opt}</button>)}
          {sel!==null && <div style={{ background:sel===item.ans?"rgba(86,207,114,0.1)":"rgba(230,57,70,0.1)", border:`1px solid ${sel===item.ans?T.green:T.red}`, borderRadius:10, padding:"10px 14px", fontSize:13, color:sel===item.ans?T.green:T.red }}>💡 {item.exp}</div>}
        </div>
      )}
      {mode==="match" && (
        <div>
          <div style={{ fontSize:12, color:T.textMuted, marginBottom:12 }}>Juftlarni bog'lang · {matched.length}/{leftItems.length}</div>
          <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:8 }}>
            <div>{leftItems.map((it,i)=>{const isMat=matched.some(m=>m.l===i);const isSel=matchSel?.type==="l"&&matchSel.i===i;return <button key={i} onClick={()=>handleMatchL(i)} disabled={isMat} style={{ width:"100%", marginBottom:8, padding:"12px 6px", borderRadius:10, border:`2px solid ${isMat?T.green:isSel?T.gold:T.border}`, background:isMat?"rgba(86,207,114,0.15)":isSel?"rgba(244,196,48,0.15)":T.card, color:isMat?T.green:isSel?T.gold:T.text, fontSize:18, fontWeight:900, cursor:isMat?"default":"pointer", textAlign:"center", opacity:isMat?0.6:1 }}>{it.zh}</button>;})}</div>
            <div>{rightItems.map((it,i)=>{const isMat=matched.some(m=>m.r===i);const isSel=matchSel?.type==="r"&&matchSel.i===i;return <button key={i} onClick={()=>handleMatchR(i)} disabled={isMat} style={{ width:"100%", marginBottom:8, padding:"12px 6px", borderRadius:10, border:`2px solid ${isMat?T.green:isSel?T.gold:T.border}`, background:isMat?"rgba(86,207,114,0.15)":isSel?"rgba(244,196,48,0.15)":T.card, color:isMat?T.green:isSel?T.gold:T.textMuted, fontSize:12, fontWeight:600, cursor:isMat?"default":"pointer", textAlign:"center", opacity:isMat?0.6:1 }}>{it.uz}</button>;})}</div>
          </div>
          {matched.length===leftItems.length && <div style={{ textAlign:"center", padding:16, background:"rgba(86,207,114,0.1)", borderRadius:12, marginTop:8 }}><div style={{ fontSize:32 }}>🏆</div><div style={{ fontSize:18, fontWeight:900, color:T.green, marginTop:4 }}>Hammasi to’g’ri!</div><button onClick={()=>{setMatched([]);setMatchSel(null);}} style={{ marginTop:10, background:T.gradient, border:"none", borderRadius:10, padding:"10px 24px", color:"#fff", fontWeight:700, cursor:"pointer" }}>🔄 Qayta</button></div>}
        </div>
      )}
      {mode==="error" && item && (
