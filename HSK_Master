      {mode==="complete" && item && (
        <div style={{ background:T.card, borderRadius:14, padding:16, border:`1px solid ${T.border}` }}>
          <div style={{ fontSize:12, color:T.gold, fontWeight:700, marginBottom:10 }}>✏️ Dialog bo’shlig’ini to’ldiring:</div>
          <div style={{ background:T.bg, borderRadius:10, padding:14, marginBottom:14, fontSize:15, color:T.text, lineHeight:2, fontWeight:600, whiteSpace:"pre-line" }}>{item.ctx}</div>
          {item.opts.map((opt,i)=>optBtn(opt,i))}
