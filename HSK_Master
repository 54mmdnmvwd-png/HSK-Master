function SpeakingSection({ lessonId }) {
  const data = SPEAKING_AUDIO_GAMES[lessonId];
  const [mode, setMode] = useState("listen");
  const [idx, setIdx] = useState(0);
  const [sel, setSel] = useState(null);
  const [score, setScore] = useState(0);
  const [total, setTotal] = useState(0);
  const [playing, setPlaying] = useState(false);
  if (!data) return <ComingSoon label="Audio o'yinlar" />;
  const speak = (text) => { speechSynthesis.cancel(); const u = new SpeechSynthesisUtterance(text); u.lang="zh-CN"; u.rate=0.75; u.onstart=()=>setPlaying(true); u.onend=()=>setPlaying(false); speechSynthesis.speak(u); };
  const items = data[mode] || [];
  const item = items[idx % Math.max(items.length,1)];
  const handleSel = (i) => { if (sel !== null) return; setSel(i); setTotal(t=>t+1); if (i === item.ans) setScore(s=>s+1); setTimeout(()=>{ setIdx(n=>(n+1)%items.length); setSel(null); }, 1100); };
  const modeColor = { listen:T.blue, whoSays:T.green, complete:T.gold };
  const mc = modeColor[mode] || T.blue;
  const optBtn = (opt,i) => { let bg=T.bg,border=T.border,color=T.text; if(sel!==null){if(i===item.ans){bg="rgba(86,207,114,0.2)";border=T.green;color=T.green;}else if(i===sel){bg="rgba(230,57,70,0.2)";border=T.red;color=T.red;}} return <button key={i} onClick={()=>handleSel(i)} style={{ width:"100%", background:bg, border:`2px solid ${border}`, borderRadius:10, padding:"13px 14px", color, fontSize:14, fontWeight:600, cursor:"pointer", marginBottom:8, textAlign:"left", transition:"all 0.2s" }}>{opt}</button>; };
  return (
    <div>
      <div style={{ background:T.card, borderRadius:12, padding:"10px 14px", marginBottom:14, border:`1px solid ${T.border}`, display:"flex", justifyContent:"space-between" }}>
        <div style={{ fontSize:13, fontWeight:700, color:T.gold }}>{data.title}</div>
        {total>0&&<div style={{ fontSize:13, color:T.textMuted }}>✓ {score}/{total}</div>}
      </div>
      <div style={{ display:"flex", gap:8, marginBottom:14 }}>
        {[["listen","🎧 Eshit & Top"],["whoSays","🗣️ Kim aytdi?"],["complete","✏️ To'ldir"]].map(([id,label])=>(
          <button key={id} onClick={()=>{setMode(id);setIdx(0);setSel(null);}}
            style={{ flex:1, padding:"9px 4px", borderRadius:10, border:`1px solid ${mode===id?modeColor[id]:T.border}`, background:mode===id?`${modeColor[id]}20`:T.card, color:mode===id?modeColor[id]:T.textMuted, fontSize:11, fontWeight:mode===id?700:400, cursor:"pointer" }}>
            {label}
          </button>
        ))}
      </div>
      <div style={{ display:"flex", justifyContent:"space-between", fontSize:11, color:T.textMuted, marginBottom:10 }}>
        <span>{idx+1}/{items.length}</span>
        <div style={{ height:4, width:"60%", background:T.border, borderRadius:2, overflow:"hidden" }}><div style={{ height:"100%", width:`${((idx+1)/items.length)*100}%`, background:mc, borderRadius:2, transition:"width 0.3s" }} /></div>
      </div>
      {mode==="listen" && item && (
        <div style={{ background:T.card, borderRadius:14, padding:16, border:`1px solid ${T.border}` }}>
          <div style={{ fontSize:12, color:T.blue, fontWeight:700, marginBottom:12 }}>🎧 Audio eshiting va ma’nosini toping:</div>
          <div style={{ textAlign:"center", marginBottom:20 }}>
            <button onClick={()=>speak(item.zh)} style={{ width:80, height:80, borderRadius:"50%", background:playing?"rgba(79,195,247,0.3)":T.gradient, border:`3px solid ${playing?T.blue:T.red}`, color:"#fff", fontSize:32, cursor:"pointer", display:"inline-flex", alignItems:"center", justifyContent:"center" }}>{playing?"⏸":"▶️"}</button>
            <div style={{ fontSize:12, color:T.textMuted, marginTop:8 }}>Bosib eshiting</div>
            <div style={{ fontSize:11, color:T.textMuted, marginTop:4, opacity:0.5 }}>{item.py}</div>
          </div>
          {item.opts.map((opt,i)=>optBtn(opt,i))}
          {sel!==null&&<div style={{ background:`${sel===item.ans?T.green:T.red}15`, border:`1px solid ${sel===item.ans?T.green:T.red}`, borderRadius:10, padding:"10px 14px", textAlign:"center" }}><div style={{ fontSize:26, fontWeight:900, color:T.text }}>{item.zh}</div><div style={{ fontSize:13, color:T.gold, marginTop:4 }}>{item.uz}</div></div>}
        </div>
      )}
      {mode==="whoSays" && item && (
        <div style={{ background:T.card, borderRadius:14, padding:16, border:`1px solid ${T.border}` }}>
          <div style={{ fontSize:12, color:T.green, fontWeight:700, marginBottom:10 }}>🗣️ Bu gapni qaysi vaziyatda aytadi?</div>
          <div style={{ background:T.bg, borderRadius:10, padding:14, marginBottom:14, display:"flex", justifyContent:"space-between", alignItems:"center" }}>
            <div style={{ fontSize:18, fontWeight:700, color:T.text, flex:1 }}>{item.zh}</div>
            <button onClick={()=>speak(item.zh)} style={{ background:"none", border:"none", fontSize:22, cursor:"pointer", marginLeft:10 }}>🔊</button>
          </div>
          {item.opts.map((opt,i)=>optBtn(opt,i))}
        </div>
